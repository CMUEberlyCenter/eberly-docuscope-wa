[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
pathlib = "*"
python-docx = "*"
beautifulsoup4 = "*"
spacy = "*"
reportlab = "*"
unidecode = "*"
fastapi = "*"
hypercorn = "*"
regex = "*"
mammoth = "*"
pillow = "*"
langcodes = "*"
en-core-web-sm = {file = "https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.8.0/en_core_web_sm-3.8.0-py3-none-any.whl"}
es-core-news-sm = {file = "https://github.com/explosion/spacy-models/releases/download/es_core_news_sm-3.8.0/es_core_news_sm-3.8.0-py3-none-any.whl"}

[dev-packages]
pylint = "*"
pycodestyle = "*"

[requires]
python_version = "3.13"

[scripts]
start = "hypercorn -b 0.0.0.0:5000 --reload  --root-path / app:app"
spacy-download = "python -m spacy download en_core_web_sm"
lint-app = "pylint app.py"
lint-document = "pylint dslib/models/document.py"
