{
  "name": "myprose",
  "version": "3.1.3",
  "description": "myProse is an environment for structuring writing tasks with the help of generative artificial intelligence and other natural language analysis tools.",
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#assets/*": "./assets/*",
    "#components/*": "./components/*",
    "#layouts/*": "./layouts/*",
    "#lib/*": "./src/lib/*",
    "#pages/*": "./pages/*",
    "#server/*": "./src/server/*"
  },
  "private": true,
  "scripts": {
    "dev": "npx bun ./index.ts",
    "build": "npx -y bun vike build",
    "build:server": "npx bun build index.ts --outdir=./build/server --target=node",
    "test": "npx bun test",
    "test:watch": "npx bun test --watch",
    "preview": "cross-env NODE_ENV=production npx bun ./index.ts",
    "start": "npm run preview",
    "prettier": "prettier -c src/ pages/ components/ layouts/",
    "eslint": "eslint src pages components layouts",
    "depcheck": "npx knip",
    "precommit": "npm run prettier && npm run eslint && npm run test && npm run gen:schema",
    "gen:schema": "npx typescript-json-schema ./tsconfig.gen.json WritingTask --out ./src/lib/WritingTask.schema.json",
    "storybook": "storybook dev -p 6006",
    "upgrade-storybook": "npx storybook@latest upgrade",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CMUEberlyCenter/eberly-docuscope-wa.git",
    "directory": "frontend"
  },
  "keywords": [
    "docuscope",
    "ontopic",
    "cmu",
    "Carnegie Mellon University",
    "english",
    "writing"
  ],
  "author": "Michael Ringenberg <Ringenberg@users.noreply.github.com> (https://www.andrew.cmu.edu/user/mringenb/)",
  "contributors": [
    "Martin van Velsen"
  ],
  "license": "CC-BY-NC-4.0",
  "bugs": {
    "url": "https://github.com/CMUEberlyCenter/eberly-docuscope-wa/issues"
  },
  "homepage": "https://www.cmu.edu/dietrich/english/research-and-publications/myprose.html",
  "browserslist": [
    "defaults"
  ],
